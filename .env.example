VECTOR_KOIOS_URL=https://v2.koios.vector.testnet.apexfusion.org/
VECTOR_EXPLORER_URL=https://vector.testnet.apexscan.org

# Wallet
VECTOR_MNEMONIC=word1 word2 ... word15
VECTOR_ACCOUNT_INDEX=0

# Safety Limits (lovelace)
VECTOR_SPEND_LIMIT_PER_TX=100000000
VECTOR_SPEND_LIMIT_DAILY=500000000

# MCP Server (SSE mode — connect to hosted Vector MCP)
# Testnet:
VECTOR_MCP_URL=https://mcp.vector.testnet.apexfusion.org/sse
# Mainnet:
# VECTOR_MCP_URL=https://mcp.vector.mainnet.apexfusion.org/sse

